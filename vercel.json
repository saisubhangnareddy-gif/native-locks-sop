{
  "version": 2,
  "cleanUrls": true,
  "functions": {
    "api/ticket.js": { "maxDuration": 30 },
    "api/raise.js": { "maxDuration": 30 }
  },
  "headers": [
    {
      "source": "/videos/:file*",
      "headers": [
        { "key": "Accept-Ranges", "value": "bytes" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ]
}
